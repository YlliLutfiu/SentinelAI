generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  createdAt DateTime   @default(now())
  analyses  Analysis[]
}

model Analysis {
  id        String   @id @default(cuid())
  type      String
  input     String
  result    Json?
  riskScore Int?
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}
